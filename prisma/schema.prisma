generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Holding {
  id            String   @id @default(uuid())
  type          GoldType
  weight        Float
  buyPrice      Float
  buyDate       DateTime
  receiptUrl    String?
  serialNumber  String?
  status        HoldingStatus @default(ACTIVE)

  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions  Transaction[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FinanceTransaction {
  id           String      @id @default(uuid())
  date         DateTime
  amount       Float
  source       String
  type         FinanceType
  purpose      String
  details      String?
  photoUrl     String?
  thumbnailUrl String?
  
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model AiSuggestion {
  id          String   @id @default(uuid())
  content     String
  date        DateTime @default(now())
  regenerated Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Transaction {
  id          String   @id @default(uuid())
  holdingId   String
  holding     Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  type        TransactionType
  price       Float
  date        DateTime

  createdAt   DateTime @default(now())
}

model PriceHistory {
  id         String   @id @default(uuid())
  type       GoldType
  weight     Float
  priceBuy   Float
  priceSell  Float?
  date       DateTime

  createdAt  DateTime @default(now())

  @@index([type, date])
}

model DailyPortfolioSummary {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  totalValue    Float
  totalCost     Float
  totalProfit   Float
  profitPercent Float

  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([date])
}

enum GoldType {
  GALERI24
  ANTAM
  UBS
}

enum HoldingStatus {
  ACTIVE
  SOLD
}

enum TransactionType {
  BUY
  SELL
}

enum FinanceType {
  DEBIT
  CREDIT
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(ADMIN)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdings            Holding[]
  summaries           DailyPortfolioSummary[]
  financeTransactions FinanceTransaction[]
  aiSuggestions       AiSuggestion[]
  financePurposes     FinancePurpose[]
}

model FinancePurpose {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, userId])
}

enum Role {
  ADMIN
  USER
}
